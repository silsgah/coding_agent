# ── Mini Coding Agent — Environment Variables ──
# Copy this to .env and fill in your values.
# These override the equivalent config.yaml settings.

# HuggingFace token (required for gated models like Llama)
HF_TOKEN=

# Model overrides
# AGENT_MODEL_NAME=Qwen/Qwen2-7B
# AGENT_DEVICE=cuda
# AGENT_BACKEND=transformers          # "transformers" or "vllm"
# AGENT_MAX_NEW_TOKENS=512

# Config file path (defaults to config/config.yaml)
# AGENT_CONFIG_PATH=config/config.yaml
